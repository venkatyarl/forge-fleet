# Example ForgeFleet canonical runtime config

[fleet]
name = "venkat-fleet"
main_node = "taylor"

[ports]
openclaw = 50000
forgefleet = 50001
model_start = 55000
model_end = 55010
docker_app_start = 60000
docker_app_end = 61000

[scheduling]
canonical_writer = "taylor"
degraded_coordinator_mode = true
use_capability_filtering = true
use_resource_aware_routing = true
use_preference_scoring = true
use_speed_to_completion = true
max_handoffs_per_task = 2

[mcp.openclaw]
server = true
client = true
port = 50000

[mcp.forgefleet]
server = true
client = true
port = 50001

[mcp.mc]
server = true
client = false
port = 60002

[nodes.taylor]
ip = "192.168.5.100"
role = ["main", "control"]

[nodes.taylor.capabilities]
control_plane = true
local_inference = true
docker = true

[nodes.taylor.resources]
cpu_cores = 32
ram_gb = 96
vram_gb = 0

[nodes.taylor.preferences]
preferred_workloads = ["control", "coordination", "fallback_reasoning"]
first_preference_workloads = []

[nodes.taylor.models.qwen35_35b]
name = "Qwen3.5-35B"
family = "qwen"
port = 55000
tier = 2
local = true
lifecycle = "production"
mode = "on_demand"
preferred_workloads = ["fallback_reasoning", "control_assist"]
