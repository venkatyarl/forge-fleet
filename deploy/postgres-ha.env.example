# Copy to .env.postgres-ha on each database host. Never commit real secrets.
# NODE_NAME must be exactly taylor, marcus, or sophie.
NODE_NAME=taylor
NODE_IP=192.168.5.100
TAYLOR_IP=192.168.5.100
MARCUS_IP=192.168.5.101
SOPHIE_IP=192.168.5.102

# pgcat-rendered passwords may not contain quotes, backslashes, or newlines.
POSTGRES_PASSWORD=replace-me
POSTGRES_REPLICATION_PASSWORD=replace-me
PGCAT_ADMIN_PASSWORD=replace-me

# Set to existing only when reusing an already-bootstrapped etcd data volume.
ETCD_INITIAL_CLUSTER_STATE=new
# Override to pin an internally mirrored pgcat image.
PGCAT_IMAGE=ghcr.io/postgresml/pgcat:latest
