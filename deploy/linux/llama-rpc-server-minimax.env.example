# Worker-node config for the MiniMax-M2.7 cluster (runs on Adele).
# Copy to ~/.forgefleet/llama-rpc-server-minimax.env on Adele, then:
#   systemctl --user enable --now llama-rpc-server@minimax
#
# Adele mounts Sia's /home/sia/models over NFS via the CX-7 fabric
# (10.42.0.1). No local download needed — the single source of truth
# is Sia's copy. See `ff fabric pair sia adele` + the NFS export.

LLAMACPP_PREFIX=/home/adele/llama.cpp/build
RPC_HOST=10.42.0.2
RPC_PORT=50052
