# Head-node config for the DeepSeek-V3.2 cluster (Rihanna + Beyonce via CX-7).
# Copy to ~/.forgefleet/llama-server-deepseek-v32.env on Rihanna, then:
#   systemctl --user enable --now llama-server@deepseek-v32
#
# Expected memory: ~123 GB per host (247 GB UD-Q2_K_XL split 2 ways).
# KV cache budget: ~5 GB per host at ctx=16384.  Tight — don't push beyond.

LLAMACPP_PREFIX=/home/rihanna/llama.cpp/build

# First shard of the 6-file UD-Q2_K_XL split.
MODEL_PATH=/home/rihanna/models/DeepSeek-V3.2-GGUF/UD-Q2_K_XL/DeepSeek-V3.2-UD-Q2_K_XL-00001-of-00006.gguf

SERVED_NAME=deepseek-v3.2
BIND_HOST=0.0.0.0
BIND_PORT=55000
CTX=16384
GPU_LAYERS=999
PARALLEL=2

# Beyonce's CX-7 fabric IP. Beyonce must run
# `llama-rpc-server@deepseek-v32` first.
RPC_PEERS=10.43.0.2:50052
