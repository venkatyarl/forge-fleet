# Head-node config for the MiniMax-M2.7 cluster (Sia + Adele via CX-7).
# Copy to ~/.forgefleet/llama-server-minimax.env on Sia, then:
#   systemctl --user enable --now llama-server@minimax
#
# Expected memory: ~90 GB per host (180 GB model split 2 ways).
# KV cache budget: ~38 GB per host at ctx=32768.

LLAMACPP_PREFIX=/home/sia/llama.cpp/build

# First shard only — llama.cpp discovers the rest of the 5-file split.
MODEL_PATH=/home/sia/models/MiniMax-M2.7-GGUF/UD-Q6_K/MiniMax-M2.7-UD-Q6_K-00001-of-00005.gguf

SERVED_NAME=minimax-m2.7
BIND_HOST=0.0.0.0
BIND_PORT=55000
CTX=32768
GPU_LAYERS=999
PARALLEL=4

# Adele's CX-7 fabric IP, rpc-server port. Adele must run
# `llama-rpc-server@minimax` first.
RPC_PEERS=10.42.0.2:50052
