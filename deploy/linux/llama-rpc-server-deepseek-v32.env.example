# Worker-node config for the DeepSeek-V3.2 cluster (runs on Beyonce).
# Copy to ~/.forgefleet/llama-rpc-server-deepseek-v32.env on Beyonce, then:
#   systemctl --user enable --now llama-rpc-server@deepseek-v32
#
# Beyonce mounts Rihanna's /home/rihanna/models over NFS via the CX-7
# fabric (10.43.0.1). NFS export was set up when the rihanna↔beyonce
# pair was configured.

LLAMACPP_PREFIX=/home/beyonce/llama.cpp/build
RPC_HOST=10.43.0.2
RPC_PORT=50052
